<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AvionActivitate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="30dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="Adauga un avion"
            android:textSize="30sp"
            android:textAlignment="center"
            />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="Denumire"
            android:textSize="20sp"
            />

        <EditText
            android:layout_width="match_parent"
            android:id="@+id/denumireavion"
            android:layout_height="50dp"
            android:hint="denumire avion..."
            />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:text="Numar locuri"
            android:textSize="20sp"
            />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="56, 87..."
            android:id="@+id/numarlocuri"
            android:inputType="number"
            />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:text="Consum mediu"
            android:textSize="20sp"
            />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:id="@+id/consummediu"
            android:hint="xy.z"
            android:inputType="numberDecimal"
            />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:text="An fabricatie"
            android:textSize="20sp"
            />


        <DatePicker
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            />


    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:text="Zboara de minim 5 ori pe saptamana?"
            android:textSize="15sp"
            />
        <Switch
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            />


    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="180dp"
            android:layout_height="50dp"
            android:text="Ce tip de confort are?"
            android:textSize="15sp"
            />
        <RadioButton
            android:layout_width="40dp"
            android:layout_height="40dp"
           />
        <TextView
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:text="Economy"/>
        <RadioButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            />
        <TextView
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:text="First Class"/>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        >
        <TextView
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Accepta termenele si conditiile."
            android:textSize="15sp"
            />
        <CheckBox
            android:layout_width="20dp"
            android:layout_height="match_parent" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        >
        <Button
            android:layout_width="200dp"
            android:id="@+id/avionplus"
            android:layout_height="50dp"
            android:text="Adauga avion"
            android:layout_gravity="center_horizontal"
            />
    </LinearLayout>

</LinearLayout>